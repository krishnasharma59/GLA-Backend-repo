<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home Feed</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container mt-4">
  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Welcome, <%= user.username %></h4>
    <div>
      <a href="./dashboard" class="btn btn-outline-primary me-2">Dashboard</a>
      <a href="/logout" class="btn btn-danger">Logout</a>
    </div>
  </div>

  <!-- Posts Feed -->
  <h5 class="mb-3">Feed</h5>

  <% if (posts.length === 0) { %>
    <p>No posts available</p>
  <% } %>

  <% posts.forEach(post => { %>
    <% if (post.userId.toString() !== user._id.toString()) { %>
      <div class="card p-3 mb-3 shadow-sm">
        <p><%= post.content %></p>
        <small class="text-muted">Posted by: <%= post.username %></small>

        <div class="mt-2">
          <form action="/like/<%= post._id %>" method="POST" style="display:inline;">
            <button class="btn btn-sm btn-outline-primary">👍 <%= post.likes.length %></button>
          </form>
        </div>

        <!-- Comments -->
        <div class="mt-3">
          <strong>Comments:</strong>

          <% if (post.comments.length === 0) { %>
            <p>No comments</p>
          <% } else { %>
            <% post.comments.forEach(c => { %>
              <div>💬 <%= c.text %></div>
            <% }) %>
          <% } %>

          <!-- Add Comment -->
          <form action="/comment/<%= post._id %>" method="POST" class="mt-2">
            <input name="text" class="form-control form-control-sm mb-1" placeholder="Write a comment..." required>
            <button class="btn btn-sm btn-secondary">Add Comment</button>
          </form>
        </div>
      </div>
    <% } %>
  <% }) %>
</div>

</body>
</html>